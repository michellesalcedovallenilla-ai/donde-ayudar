---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import type { Lang } from '../data/types';
import { canonicalPath, href } from '../i18n/utils';

interface Props {
  title: string;
  description: string;
  lang: Lang;
}

const { title, description, lang } = Astro.props;
const fullTitle = title ? `${title} · Donde Ayudar` : 'Donde Ayudar';

const canonical = canonicalPath(Astro.url.pathname);
const esUrl = new URL(href(canonical, 'es'), Astro.site);
const enUrl = new URL(href(canonical, 'en'), Astro.site);
const selfUrl = new URL(Astro.url.pathname, Astro.site);
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="canonical" href={selfUrl.href} />
    <link rel="alternate" hreflang="es" href={esUrl.href} />
    <link rel="alternate" hreflang="en" href={enUrl.href} />
    <link rel="alternate" hreflang="x-default" href={esUrl.href} />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:locale" content={lang === 'es' ? 'es_VE' : 'en_US'} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;500;600;700;800&display=swap"
      rel="stylesheet"
    />
    <title>{fullTitle}</title>
  </head>
  <body>
    <a href="#main" class="skip-link">{lang === 'es' ? 'Saltar al contenido' : 'Skip to content'}</a>
    <Header lang={lang} />
    <main id="main">
      <slot />
    </main>
    <Footer lang={lang} />
  </body>
</html>
