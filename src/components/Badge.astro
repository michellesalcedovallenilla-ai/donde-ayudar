---
/** Status / work-mode / ally badge. Variant maps to a class in global.css;
 *  unknown variants fall back to the neutral grey badge. */
interface Props {
  variant?: 'verified' | 'urgent' | 'pending' | 'remoto' | 'presencial' | 'hibrido' | 'ally' | 'neutral';
  label: string;
  dot?: boolean;
}
const { variant = 'neutral', label, dot = false } = Astro.props;
const variantClass = ['verified', 'urgent', 'remoto', 'presencial', 'ally'].includes(variant) ? variant : '';
---

<span class:list={['badge', variantClass]}>
  {dot && <span class="dot"></span>}
  {label}
</span>
