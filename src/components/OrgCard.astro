---
import type { Organizacion, Lang } from '../data/types';
import { pick } from '../data/types';
import { useStrings } from '../data/strings';
import Badge from './Badge.astro';
import Icon from './Icon.astro';

interface Props {
  org: Organizacion;
  lang: Lang;
}
const { org, lang } = Astro.props;
const t = useStrings(lang);

const isEmail = org.contact.includes('@') && !org.contact.startsWith('http');
const contactHref = isEmail ? `mailto:${org.contact}` : org.contact;
const contactLabel = isEmail ? t.escribir : t.contactar;
const areas = pick(org.areas, lang);
const hasWebsite = !!org.website && org.website !== '#';
---

<article class="card org-card">
  <div class="row">
    <Badge variant="neutral" label={pick(org.type, lang)} />
    {
      org.verified ? (
        <Badge variant="ally" label={t.allyLabel} dot />
      ) : (
        <Badge variant="pending" label={t.orgPendiente} dot />
      )
    }
  </div>
  <h3>{pick(org.title, lang)}</h3>
  <span class="loc"><Icon name="map-pin" size={14} />{pick(org.location, lang)}</span>
  <p class="desc">{pick(org.description, lang)}</p>
  <div>
    <span class="kicker">{t.areasApoyo}</span>
    <ul class="pill-list areas">
      {areas.map((a) => <li class="pill">{a}</li>)}
    </ul>
  </div>
  <div class="actions">
    <a class="btn btn-blue" href={contactHref} rel="noopener">
      <Icon name="mail" size={15} />{contactLabel}
    </a>
    {
      hasWebsite && (
        <a class="btn btn-ghost" href={org.website!} target="_blank" rel="noopener noreferrer">
          {t.sitioWeb}
          <Icon name="arrow-up-right" size={15} />
        </a>
      )
    }
  </div>
</article>

<style>
  .org-card {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }
  .row {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 10px;
    flex-wrap: wrap;
  }
  h3 {
    font-size: 18.5px;
    font-weight: 700;
    color: var(--acc);
    margin: 4px 0 0;
    line-height: 1.3;
  }
  .loc {
    display: inline-flex;
    align-items: center;
    gap: 5px;
    color: var(--txm);
    font-size: 13.5px;
  }
  .desc {
    margin: 0;
    color: var(--txs);
    font-size: 14.5px;
    line-height: 1.6;
  }
  .areas {
    margin-top: 6px;
  }
  .actions {
    margin-top: auto;
    padding-top: 10px;
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
  }
  .actions .btn {
    padding: 10px 18px;
    font-size: 14px;
  }
</style>
