---
/**
 * Thin wrapper around astro-icon using the Lucide set.
 * Icons are inlined as SVG at build time — no runtime JS, no CDN.
 */
import { Icon as AstroIcon } from 'astro-icon/components';

interface Props {
  name: string;
  size?: number;
  class?: string;
  'aria-hidden'?: boolean;
}

const { name, size = 18, class: className, ...rest } = Astro.props;
---

<AstroIcon
  name={`lucide:${name}`}
  width={size}
  height={size}
  class={className}
  aria-hidden="true"
  {...rest}
/>
