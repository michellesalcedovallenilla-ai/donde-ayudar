---
import type { Lang } from '../../data/types';
import { useStrings } from '../../data/strings';
import { organizaciones } from '../../data/organizaciones';
import { paths } from '../../data/site';
import { href } from '../../i18n/utils';
import OrgCard from '../OrgCard.astro';
import Icon from '../Icon.astro';

interface Props {
  lang: Lang;
}
const { lang } = Astro.props;
const t = useStrings(lang);
---

<section class="page-hero">
  <div class="container">
    <p class="eyebrow red">{t.orgsPEyebrow}</p>
    <h1 class="h1">{t.orgsPH1}</h1>
    <p class="lead">{t.orgsPLead}</p>
  </div>
</section>

<section class="section">
  <div class="container">
    <div class="grid grid-cards orgs-grid">
      {organizaciones.map((org) => <OrgCard org={org} lang={lang} />)}
    </div>

    <div class="notice join">
      <Icon name="handshake" size={24} class="ico" />
      <p><strong>{t.sumarseT}</strong> {t.sumarseX}</p>
      <a class="btn btn-yellow" href={href(paths.publicar, lang)}>
        {t.sumarseBtn}<Icon name="arrow-right" size={16} />
      </a>
    </div>
  </div>
</section>

<style>
  .orgs-grid {
    margin-bottom: 30px;
  }
  .join {
    align-items: center;
    flex-wrap: wrap;
  }
  .join p {
    flex: 1 1 300px;
    margin: 0;
  }
  .join strong {
    display: inline;
  }
</style>
