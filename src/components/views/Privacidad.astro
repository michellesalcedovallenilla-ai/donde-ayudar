---
import type { Lang } from '../../data/types';
import { useStrings } from '../../data/strings';
import Icon from '../Icon.astro';

interface Props {
  lang: Lang;
}
const { lang } = Astro.props;
const t = useStrings(lang);

const siList = [t.si1, t.si2, t.si3, t.si4];
const noList = [t.no1, t.no2, t.no3, t.no4];
---

<section class="page-hero">
  <div class="container">
    <p class="eyebrow red">{t.privEyebrow}</p>
    <h1 class="h1">{t.privH1}</h1>
    <p class="lead">{t.privLead}</p>
  </div>
</section>

<section class="section">
  <div class="container narrow">
    <div class="grid lim-grid">
      <div class="card">
        <h2 class="lim-title yes"><span class="lim-mark yes"><Icon name="check" size={18} /></span>{t.siT}</h2>
        <ul class="lim-list">
          {siList.map((item) => <li><Icon name="check" size={17} class="yes-ico" />{item}</li>)}
        </ul>
      </div>
      <div class="card">
        <h2 class="lim-title no"><span class="lim-mark no"><Icon name="x" size={18} /></span>{t.noT}</h2>
        <ul class="lim-list">
          {noList.map((item) => <li><Icon name="x" size={17} class="no-ico" />{item}</li>)}
        </ul>
      </div>
    </div>
    <div class="notice lim-note">
      <Icon name="heart-handshake" size={23} class="ico" />
      <p><strong>{t.compT}</strong>{t.compX}</p>
    </div>
  </div>
</section>

<style>
  .narrow {
    max-width: 920px;
  }
  .lim-grid {
    grid-template-columns: repeat(auto-fit, minmax(290px, 1fr));
  }
  .lim-title {
    display: flex;
    align-items: center;
    gap: 9px;
    font-size: 17px;
    font-weight: 700;
    margin: 0 0 16px;
  }
  .lim-title.yes { color: var(--grn); }
  .lim-title.no { color: var(--red); }
  .lim-mark {
    display: inline-flex;
    width: 30px;
    height: 30px;
    border-radius: 9px;
    align-items: center;
    justify-content: center;
  }
  .lim-mark.yes { background: var(--grns); }
  .lim-mark.no { background: var(--reds); }
  .lim-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    gap: 11px;
  }
  .lim-list li {
    display: flex;
    gap: 9px;
    font-size: 14.5px;
    color: var(--txs);
    line-height: 1.5;
  }
  .lim-list :global(.yes-ico) { color: var(--grn); flex: 0 0 auto; margin-top: 2px; }
  .lim-list :global(.no-ico) { color: var(--red); flex: 0 0 auto; margin-top: 2px; }
  .lim-note {
    margin-top: 24px;
  }
</style>
