---
import type { Lang } from '../data/types';
import { useStrings } from '../data/strings';
import { mainNav, paths } from '../data/site';
import { href, canonicalPath, switchLocalePath } from '../i18n/utils';
import Icon from './Icon.astro';

interface Props {
  lang: Lang;
}
const { lang } = Astro.props;
const t = useStrings(lang);

const current = canonicalPath(Astro.url.pathname);
const isActive = (p: string) => (p === '/' ? current === '/' : current.startsWith(p));

const otherLang: Lang = lang === 'es' ? 'en' : 'es';
const switchHref = switchLocalePath(Astro.url.pathname, otherLang);
const otherLabel = lang === 'es' ? 'EN' : 'ES';
---

<header class="site-header">
  <div class="container bar">
    <a href={href(paths.home, lang)} class="brand" aria-label="Donde Ayudar">
      <img src="/assets/logo-icon.png" alt="" width="38" height="38" />
      <span>Donde Ayudar</span>
    </a>

    <nav class="desktop-nav" aria-label={lang === 'es' ? 'Navegación' : 'Navigation'}>
      {
        mainNav.map((item) => (
          <a
            href={href(item.path, lang)}
            class:list={['nav-link', { active: isActive(item.path) }]}
            aria-current={isActive(item.path) ? 'page' : undefined}
          >
            {t[item.label]}
          </a>
        ))
      }
      <span class="divider"></span>
      <a class="lang-btn" href={switchHref} title={t.langSwitch} aria-label={t.langSwitch}>
        <Icon name="languages" size={16} />{otherLabel}
      </a>
      <a class="btn btn-yellow cta" href={href(paths.publicar, lang)}>
        <Icon name="megaphone" size={16} />{t.ctaPublicar}
      </a>
    </nav>

    <div class="mobile-controls">
      <a class="lang-btn" href={switchHref} aria-label={t.langSwitch}>
        <Icon name="languages" size={16} />{otherLabel}
      </a>
      <button type="button" class="menu-toggle" aria-expanded="false" aria-controls="mobile-drawer" aria-label="Menu">
        <Icon name="menu" size={22} class="i-open" />
        <Icon name="x" size={22} class="i-close" />
      </button>
    </div>
  </div>

  <div class="mobile-drawer" id="mobile-drawer" hidden>
    {
      mainNav.map((item) => (
        <a href={href(item.path, lang)} class="drawer-link">
          {t[item.label]}
        </a>
      ))
    }
    <a class="btn btn-yellow btn-full" href={href(paths.publicar, lang)}>
      <Icon name="megaphone" size={18} />{t.ctaPublicar}
    </a>
  </div>
</header>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 60;
    background: var(--srf);
    border-bottom: 1px solid var(--bd);
    box-shadow: 0 1px 0 var(--shc);
  }
  .bar {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 14px;
    padding-block: 12px;
  }
  .brand {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    flex: 0 0 auto;
  }
  .brand img {
    height: 38px;
    width: auto;
    display: block;
  }
  .brand span {
    font-weight: 700;
    font-size: 18px;
    color: var(--acc);
    letter-spacing: -0.01em;
  }

  .desktop-nav {
    display: flex;
    align-items: center;
    gap: 2px;
  }
  .nav-link {
    position: relative;
    display: inline-flex;
    align-items: center;
    padding: 9px 12px;
    border-radius: 10px;
    font-size: 14.5px;
    font-weight: 500;
    color: var(--txt);
    white-space: nowrap;
  }
  .nav-link:hover {
    color: var(--acc);
  }
  .nav-link.active::after {
    content: '';
    position: absolute;
    left: 13px;
    right: 13px;
    bottom: 1px;
    height: 2.5px;
    border-radius: 2px;
    background: var(--yel);
  }
  .divider {
    width: 1px;
    height: 24px;
    background: var(--bd);
    margin: 0 8px;
  }
  .lang-btn {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 8px 12px;
    border-radius: 999px;
    border: 1.5px solid var(--bd2);
    background: var(--srf);
    color: var(--txt);
    font-weight: 600;
    font-size: 13px;
  }
  .lang-btn:hover {
    border-color: var(--acc);
    color: var(--acc);
  }
  .cta {
    margin-left: 6px;
    padding: 11px 18px;
    font-size: 14.5px;
  }

  .mobile-controls {
    display: none;
    align-items: center;
    gap: 8px;
  }
  .menu-toggle {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 42px;
    height: 42px;
    border: 1.5px solid var(--bd2);
    border-radius: 11px;
    background: var(--srf);
    color: var(--acc);
    cursor: pointer;
  }
  .menu-toggle .i-close {
    display: none;
  }
  .menu-toggle[aria-expanded='true'] .i-open {
    display: none;
  }
  .menu-toggle[aria-expanded='true'] .i-close {
    display: inline-flex;
  }

  .mobile-drawer {
    border-top: 1px solid var(--bd);
    background: var(--srf);
    box-shadow: 0 18px 30px var(--shc);
    padding: 10px 18px 18px;
    display: flex;
    flex-direction: column;
    gap: 4px;
  }
  .mobile-drawer[hidden] {
    display: none;
  }
  .drawer-link {
    padding: 14px;
    border-radius: 12px;
    font-size: 16px;
    font-weight: 500;
    color: var(--txt);
  }
  .drawer-link:hover {
    background: var(--soft);
  }
  .mobile-drawer .btn {
    margin-top: 8px;
  }

  @media (max-width: 1023px) {
    .desktop-nav {
      display: none;
    }
    .mobile-controls {
      display: flex;
    }
  }
</style>

<script>
  const toggle = document.querySelector<HTMLButtonElement>('.menu-toggle');
  const drawer = document.getElementById('mobile-drawer');
  toggle?.addEventListener('click', () => {
    const open = toggle.getAttribute('aria-expanded') === 'true';
    toggle.setAttribute('aria-expanded', String(!open));
    if (drawer) drawer.hidden = open;
  });
</script>
