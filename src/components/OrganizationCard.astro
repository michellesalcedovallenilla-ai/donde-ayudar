---
import Badge from './Badge.astro';
import type { CollectionEntry } from 'astro:content';

interface Props {
  organizacion: CollectionEntry<'organizaciones'>;
}

const { organizacion } = Astro.props;
const { data } = organizacion;

const isEmail = data.contact.includes('@') && !data.contact.startsWith('http');
const contactHref = isEmail ? `mailto:${data.contact}` : data.contact;
---

<article class="card">
  <div class="tag-row" style="justify-content:space-between; align-items:center">
    <Badge variant="neutral">{data.type}</Badge>
    {data.verified ? <Badge variant="ally" /> : <Badge variant="pending" />}
  </div>

  <h3 style="margin:0">{data.title}</h3>
  <span class="muted" style="font-size:0.88rem">📍 {data.location}</span>

  <p class="muted" style="margin:0; font-size:0.95rem">{data.description}</p>

  {
    data.areasOfSupport.length > 0 && (
      <div>
        <span class="muted" style="font-size:0.78rem; text-transform:uppercase; letter-spacing:0.06em">
          Áreas de apoyo
        </span>
        <ul class="pill-list">
          {data.areasOfSupport.map((area) => <li>{area}</li>)}
        </ul>
      </div>
    )
  }

  <div class="card-footer tag-row">
    <a href={contactHref} class="btn btn-outline" rel="noopener">
      {isEmail ? 'Escribir' : 'Contactar'}
    </a>
    {
      data.website && (
        <a href={data.website} class="btn btn-outline" target="_blank" rel="noopener noreferrer">
          Sitio web ↗
        </a>
      )
    }
  </div>
</article>
