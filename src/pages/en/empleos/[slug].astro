---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import EmpleoDetail from '../../../components/views/EmpleoDetail.astro';
import { empleos } from '../../../data/empleos';
import { pick } from '../../../data/types';

export function getStaticPaths() {
  return empleos.map((empleo) => ({ params: { slug: empleo.id }, props: { empleo } }));
}

const { empleo } = Astro.props;
const lang = 'en' as const;
---

<BaseLayout title={pick(empleo.title, lang)} description={pick(empleo.description, lang)} lang={lang}>
  <EmpleoDetail empleo={empleo} lang={lang} />
</BaseLayout>
