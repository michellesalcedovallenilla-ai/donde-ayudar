---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import CasoDetail from '../../../components/views/CasoDetail.astro';
import { casos } from '../../../data/casos';
import { pick } from '../../../data/types';

export function getStaticPaths() {
  return casos.map((caso) => ({ params: { slug: caso.id }, props: { caso } }));
}

const { caso } = Astro.props;
const lang = 'en' as const;
---

<BaseLayout title={pick(caso.title, lang)} description={pick(caso.summary, lang)} lang={lang}>
  <CasoDetail caso={caso} lang={lang} />
</BaseLayout>
