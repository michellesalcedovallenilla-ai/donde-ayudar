---
import BaseLayout from '../layouts/BaseLayout.astro';

// Correo de destino para los formularios (mailto). Cámbialo por el real.
const inbox = 'oportunidades@dondeayudar.example';
const inboxOrg = 'aliados@dondeayudar.example';
---

<BaseLayout
  title="Publicar una oportunidad"
  description="Recruiters y empresas: publica una oportunidad remota y ayuda a una familia afectada a recuperar estabilidad económica."
>
  <section class="page-intro">
    <div class="container">
      <p class="eyebrow">Para recruiters y empresas</p>
      <h1>Publica una oportunidad remota</h1>
      <p class="lead">
        Publica una oportunidad remota y ayuda a una familia afectada a recuperar estabilidad
        económica. Revisamos cada propuesta manualmente antes de publicarla.
      </p>
    </div>
  </section>

  <section class="section" style="padding-top:0">
    <div class="container">
      <div class="detail-grid">
        <!-- Formulario de empleo (visual, sin backend) -->
        <div class="detail-body">
          <div class="form-card" id="oportunidad">
            <h2 style="margin-top:0">Detalles de la oportunidad</h2>
            <p class="muted">
              Este formulario abre tu cliente de correo con la información ya redactada. No
              guardamos nada en servidores: tú envías el correo y nosotros lo curamos.
            </p>

            <form
              data-mailto-form
              data-inbox={inbox}
              data-subject="Nueva oportunidad remota"
            >
              <div class="form-row">
                <div class="form-field">
                  <label for="puesto">Título del puesto *</label>
                  <input id="puesto" name="Puesto" required placeholder="Ej. Agente de soporte bilingüe" />
                </div>
                <div class="form-field">
                  <label for="empresa">Empresa *</label>
                  <input id="empresa" name="Empresa" required placeholder="Nombre de tu empresa" />
                </div>
              </div>

              <div class="form-row">
                <div class="form-field">
                  <label for="modalidad">Modalidad remota *</label>
                  <select id="modalidad" name="Modalidad" required>
                    <option value="100% remoto">100% remoto</option>
                    <option value="Remoto LatAm">Remoto LatAm</option>
                    <option value="Remoto global">Remoto global</option>
                    <option value="Híbrido">Híbrido</option>
                  </select>
                </div>
                <div class="form-field">
                  <label for="categoria">Categoría *</label>
                  <input id="categoria" name="Categoria" required placeholder="Ej. Tecnología, Diseño, Administración" />
                </div>
              </div>

              <div class="form-field">
                <label for="descripcion">Descripción del rol *</label>
                <textarea id="descripcion" name="Descripcion" rows="4" required
                  placeholder="Responsabilidades, requisitos clave y lo que ofrece la empresa"></textarea>
              </div>

              <div class="form-field">
                <label for="aplicar">Link para aplicar *</label>
                <input id="aplicar" name="Link_para_aplicar" type="url" required placeholder="https://..." />
              </div>

              <div class="form-field">
                <label for="contacto-emp">Tu correo de contacto *</label>
                <input id="contacto-emp" name="Contacto" type="email" required placeholder="tu@empresa.com" />
              </div>

              <button type="submit" class="btn btn-primary btn-block">
                Enviar oportunidad por correo
              </button>
            </form>
          </div>

          <!-- Formulario de organización -->
          <div class="form-card mt-3" id="organizacion">
            <h2 style="margin-top:0">Conectar una organización</h2>
            <p class="muted">
              ¿Eres una fundación, refugio, centro de acopio o red de voluntarios? Súmate
              como aliado para verificar casos y canalizar ayuda.
            </p>

            <form
              data-mailto-form
              data-inbox={inboxOrg}
              data-subject="Nueva organización aliada"
            >
              <div class="form-row">
                <div class="form-field">
                  <label for="org-nombre">Nombre de la organización *</label>
                  <input id="org-nombre" name="Organizacion" required />
                </div>
                <div class="form-field">
                  <label for="org-tipo">Tipo *</label>
                  <input id="org-tipo" name="Tipo" required placeholder="Fundación, refugio, centro de acopio…" />
                </div>
              </div>

              <div class="form-field">
                <label for="org-areas">Áreas de apoyo *</label>
                <input id="org-areas" name="Areas_de_apoyo" required placeholder="Verificación, alimentos, mentoría…" />
              </div>

              <div class="form-field">
                <label for="org-contacto">Correo o canal de contacto *</label>
                <input id="org-contacto" name="Contacto" required placeholder="contacto@organizacion.org" />
              </div>

              <button type="submit" class="btn btn-secondary btn-block">
                Enviar solicitud de alianza
              </button>
            </form>
          </div>
        </div>

        <!-- Aside informativo -->
        <aside>
          <div class="detail-card">
            <h3>Cómo curamos</h3>
            <ol style="padding-left:1.1rem; margin:0; display:grid; gap:0.7rem; color:var(--color-text-soft)">
              <li>Recibimos tu propuesta por correo.</li>
              <li>Verificamos que sea una oferta remota real y segura.</li>
              <li>La publicamos como caso/empleo curado.</li>
              <li>Conectamos con perfiles afines de La Guaira.</li>
            </ol>

            <div class="notice mt-3">
              <span aria-hidden="true">🔒</span>
              <div>
                <strong>Sin backend, sin datos sensibles</strong>
                Estos formularios solo abren tu correo. No almacenamos información en
                servidores ni procesamos pagos.
              </div>
            </div>

            <p class="muted mt-2" style="font-size:0.88rem">
              ¿Prefieres escribir directo?
              <a href={`mailto:${inbox}`}>{inbox}</a>
            </p>
          </div>
        </aside>
      </div>
    </div>
  </section>
</BaseLayout>

<script>
  // Convierte cada formulario en un mailto prellenado. Sin servidores.
  document.querySelectorAll('[data-mailto-form]').forEach((form) => {
    form.addEventListener('submit', (event) => {
      event.preventDefault();
      const el = form as HTMLFormElement;
      const inbox = el.dataset.inbox ?? '';
      const subject = el.dataset.subject ?? 'Mensaje';
      const data = new FormData(el);
      const lines: string[] = [];
      for (const [key, value] of data.entries()) {
        if (typeof value === 'string' && value.trim()) {
          lines.push(`${key.replace(/_/g, ' ')}: ${value}`);
        }
      }
      const body = encodeURIComponent(lines.join('\n'));
      window.location.href = `mailto:${inbox}?subject=${encodeURIComponent(subject)}&body=${body}`;
    });
  });
</script>
